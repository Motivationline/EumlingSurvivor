id = "baugeraetefuehrer"
type = 4
type_secondary = 1
type_tertiary = 3
name = "Baugeräteführer*in"
info = "Baugeräteführer*innen transportieren z.B. Kräne, Planierraupen, Walzen, Bagger oder Betonmischgeräte vor Beginn der Bauarbeiten zur Baustelle und sorgen für die Betriebsbereitschaft und Sicherung der Baustelle. Sie führen und bedienen Baumaschinen, z.B. führen sie Erdbewegungsarbeiten mit Baggern durch, transportieren Bauteile mit Kränen, bedienen Geräte für den Straßenbau, warten und pflegen zudem die Baugeräte, erledigen kleinere Reparaturen und rüsten die Baumaschinen bei Bedarf um, z.B. wechseln sie mobile Zusatzgeräte aus."
image = ExtResource("1_6mr8x")
education = "Ausbildung"
url = "https://web.arbeitsagentur.de/berufenet/beruf/4823"
