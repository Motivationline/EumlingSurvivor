script = ExtResource("2_k28dc")
id = "pferdewirt_klassische_reitausbildung"
type = 5
type_secondary = 4
type_tertiary = 2
name = "Pferdewirt/in - Klassische Reitausbildung"
info = " Pferdewirte und Pferdewirtinnen der Fachrichtung Klassische Reitausbildung beurteilen die Eignung von Pferden für spezifische Verwendungszwecke und Disziplinen, bilden sie in der Dressur und im Springen aus und trainieren sie.

Sie beraten Kunden und unterrichten sie im klassischen Reitsport. Darüber hinaus füttern, tränken und pflegen sie die Tiere, sorgen für ausreichende Bewegung sowie für artgerechten Transport und halten Stall und Ausrüstung sauber. Auch den Gesundheitszustand der Pferde behalten sie stets im Auge."
image = ExtResource("1_t0vu6")
education = "Ausbildung"
