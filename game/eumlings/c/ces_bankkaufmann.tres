script = ExtResource("1_e16gb")
id = "bankkaufmann"
type = 1
type_secondary = 2
type_tertiary = 5
name = "Bankkaufmann/-frau"
info = "Bankkaufleute unterstützen Kunden in Geldangelegenheiten. Sie informieren z.B. über Kapitalanlagen, Kontoführung und wickeln den in- oder ausländischen Zahlungsverkehr für Kunden ab. Sie beraten individuell zu Privat- und Firmenkrediten, Bausparverträgen, Lebensversicherungen oder anderen Verträgen, bahnen Vertragsabschlüsse an und bearbeiten diese. Im internen Bereich eines Kreditinstitutes planen und steuern sie Arbeitsabläufe. Darüber hinaus führen sie Kontrollen im Rechnungswesen durch und überwachen die Einhaltung gesetzlicher Vorschriften und innerbetrieblicher Richtlinien."
image = ExtResource("1_obvb1")
education = "Ausbildung"
metadata/_custom_type_script = "uid://crtc25lk2dk4x"
