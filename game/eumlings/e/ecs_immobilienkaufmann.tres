[resource]
script = ExtResource("1_8xmia")
id = "immobilienkaufmann"
type = 2
type_secondary = 1
type_tertiary = 5
name = "Immobilienkaufmann/-frau"
info = "Immobilienkaufleute bewirtschaften Grundstücke, Wohnhäuser und gewerbliche Immobilien, vermieten und verwalten, kaufen, verkaufen oder vermitteln Objekte, organisieren Objektbesichtigungen und wickeln Wohnungsübernahmen ab. Sie wirken bei der Planung und Organisation von Neubau-, Sanierungs- oder Modernisierungsprojekten mit und nehmen fertige Bauten ab. In der Wohnungs- oder Gebäudeverwaltung beraten sie z.B. Mieter und Eigentümer, bearbeiten Schadensmeldungen und veranlassen Instandsetzungsarbeiten. Sie führen Mieter- bzw. Eigentümerversammlungen durch und organisieren das technische Gebäudemanagement. Darüber hinaus bereiten sie Finanzierungskonzepte vor, erstellen Bau- und Betriebskostenabrechnungen, Wirtschafts- und Finanzpläne oder wirken in der kaufmännischen Steuerung und Kontrolle mit. Im Bereich Öffentlichkeitsarbeit entwickeln sie u.a. Marketingmaßnahmen."
image = ExtResource("1_104to")
education = "Ausbildung"
metadata/_custom_type_script = "uid://crtc25lk2dk4x"
