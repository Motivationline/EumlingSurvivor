[gd_scene format=3 uid="uid://dm4mgjmi078lm"]

[sub_resource type="GDScript" id="GDScript_v754s"]
script/source = "extends Node3D

## How far from the center of the entity can the damage number be offset
@export var max_offset: float = 0.2

var text: String:
	set(value):
		$DamageNumberLabel.text = value
		text = value

func _ready() -> void:
	position.x += randf_range(-max_offset, max_offset)
	position.z += randf_range(-max_offset, max_offset)
"

