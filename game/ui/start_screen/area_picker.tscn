[sub_resource type="GDScript" id="GDScript_i6bfq"]
script/source = "extends Control

@onready var line_edit: LineEdit = %DebugLevelInput

signal level_chosen(level: String)
signal abort()

func setup():
	show()
	line_edit.text = \"\"
	line_edit.grab_focus.call_deferred()

func _on_line_edit_text_submitted(_new_text: String) -> void:
	confirm_text()

func _on_button_confirm_pressed() -> void:
	confirm_text()

func confirm_text():
	hide()
	level_chosen.emit(line_edit.text)

func _on_button_cancel_pressed() -> void:
	abort.emit()
	hide()
"

